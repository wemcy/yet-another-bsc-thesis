# -----------------------------------------------------------------------
# Environment variable template - copy to .env and fill in real values
# .env is gitignored and must never be committed
# -----------------------------------------------------------------------

# -- ASP.NET Core --
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080

# -- Database --
ConnectionStrings__Default=Host=db;Database=recipeapp;Username=postgres;Password=CHANGE_ME

# -- Admin seed user --
Admin__Email=admin@recipe-app.local
Admin__Password=CHANGE_ME
Admin__DisplayName=Administrator

# -- CORS (add one entry per allowed frontend origin) --
Cors__AllowedOrigins__0=https://your-frontend.example.com

# -- Pagination --
Pagination__DefaultPageSize=25

# -- Image sizes (pixels) --
ImageSizes__Thumbnail__Width=50
ImageSizes__Thumbnail__Height=50
ImageSizes__Medium__Width=200
ImageSizes__Medium__Height=200
ImageSizes__Large__Width=500
ImageSizes__Large__Height=500
